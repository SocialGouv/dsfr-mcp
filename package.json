{
  "name": "dsfr-mcp",
  "version": "1.0.0",
  "description": "MCP server pour la documentation DSFR (Système de Design de l'État français)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocialGouv/dsfr-mcp.git"
  },
  "homepage": "https://github.com/SocialGouv/dsfr-mcp#readme",
  "bugs": {
    "url": "https://github.com/SocialGouv/dsfr-mcp/issues"
  },
  "main": "build/index.js",
  "module": "src/smithery.ts",
  "bin": {
    "dsfr-mcp": "build/index.js"
  },
  "files": [
    "build",
    "docs"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-docs": "tsx scripts/fetch-docs.ts",
    "setup": "pnpm run fetch-docs && pnpm build",
    "prepublishOnly": "pnpm run setup",
    "smithery:dev": "smithery dev",
    "smithery:build": "smithery build"
  },
  "keywords": [
    "mcp",
    "dsfr",
    "design-system"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@smithery/cli": "^4.11.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "hono@<4.12.21": "^4.12.21",
      "@hono/node-server@<1.19.13": "^1.19.13",
      "fast-uri@<=3.1.1": "^3.1.2",
      "path-to-regexp@>=8.0.0 <8.4.0": "^8.4.0",
      "express-rate-limit@>=8.2.0 <8.2.2": "^8.2.2",
      "ip-address@<=10.1.0": "^10.1.1",
      "qs@>=6.11.1 <=6.15.1": "^6.15.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "esbuild@<0.28.1": "^0.28.1",
      "vite@>=7.0.0 <7.3.5": "^7.3.5",
      "rollup@<4.59.0": "^4.59.0",
      "postcss@<8.5.10": "^8.5.10"
    }
  }
}
